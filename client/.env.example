# Local dev only: where `npm run dev`'s proxy forwards /api requests. Defaults to http://localhost:5000.
VITE_DEV_BACKEND_URL=http://localhost:5000

# Production: full API URL of the deployed backend (frontend and backend are usually on
# different hosts). Leave unset for local dev — the proxy above handles it.
# VITE_API_URL=https://your-backend-domain.com/api
